# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_here
ADMIN_KEY=your_admin_key_here

# Database Configuration (Supabase/Postgres)
DATABASE_URL=postgres://user:password@host:port/dbname

# Third-Party API Keys
GOOGLE_CLIENT_ID=your_google_client_id_here
GIPHY_API_KEY=your_giphy_api_key_here
IMGBB_API_KEY=your_imgbb_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# TURN Server (optional — for reliable WebRTC calls on production)
# Sign up free at https://www.metered.ca/ then paste your API key here
# Without this, falls back to Open Relay Project (free, 500MB/month limit)
METERED_API_KEY=your_metered_api_key_here
